# Anthropic API key — used by /api/mcp/* routes (server-side only, never exposed to browser)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# (Optional) Anthropic model used for MCP tool orchestration.
# Default: claude-sonnet-4-20250514
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 심사숙고 MCP 서버 SSE 엔드포인트
SIMSASUKGO_MCP_URL=https://simsasukgo-mcp.greenflower-c8b70739.eastus2.azurecontainerapps.io/sse
SIMSASUKGO_MCP_NAME=심사숙고
